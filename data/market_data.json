<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trading Dashboard - Advanced Analysis</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1600px;
            margin: 0 auto;
        }
        
        header {
            text-align: center;
            color: white;
            margin-bottom: 40px;
            padding: 20px;
        }
        
        header h1 {
            font-size: 3em;
            margin-bottom: 15px;
            font-weight: 700;
            text-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }
        
        .last-update {
            font-size: 1.1em;
            opacity: 0.95;
            background: rgba(255,255,255,0.15);
            padding: 10px 25px;
            border-radius: 25px;
            display: inline-block;
            backdrop-filter: blur(10px);
        }
        
        /* MACRO ANALYSIS SECTION */
        .macro-section {
            margin-bottom: 40px;
        }
        
        .section-title {
            color: white;
            font-size: 2em;
            margin-bottom: 25px;
            text-align: center;
            font-weight: 700;
        }
        
        .macro-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
            gap: 30px;
            margin-bottom: 40px;
        }
        
        .macro-card {
            background: white;
            border-radius: 25px;
            padding: 35px;
            box-shadow: 0 25px 80px rgba(0,0,0,0.25);
            transition: transform 0.3s ease;
        }
        
        .macro-card:hover {
            transform: translateY(-5px);
        }
        
        .pair-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 3px solid #f0f0f0;
        }
        
        .pair-name {
            font-size: 2em;
            font-weight: 800;
            color: #2c3e50;
        }
        
        .pair-price {
            font-size: 1.8em;
            font-weight: 700;
            color: #7f8c8d;
        }
        
        /* SCORE GAUGE */
        .score-container {
            text-align: center;
            margin: 30px 0;
        }
        
        .score-label {
            font-size: 0.9em;
            color: #95a5a6;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 15px;
        }
        
        .score-gauge {
            position: relative;
            width: 200px;
            height: 200px;
            margin: 0 auto 20px;
        }
        
        .gauge-bg {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: conic-gradient(
                #e74c3c 0deg,
                #e74c3c 108deg,
                #fdcb6e 108deg,
                #fdcb6e 180deg,
                #00b894 180deg,
                #00b894 360deg
            );
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .gauge-inner {
            width: 140px;
            height: 140px;
            background: white;
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        
        .score-value {
            font-size: 3.5em;
            font-weight: 800;
            line-height: 1;
        }
        
        .score-max {
            font-size: 1.2em;
            color: #95a5a6;
            font-weight: 600;
        }
        
        .signal-badge {
            font-size: 1.8em;
            font-weight: 700;
            padding: 15px 30px;
            border-radius: 50px;
            margin: 15px 0;
            display: inline-block;
        }
        
        .recommendation {
            font-size: 1.1em;
            color: #7f8c8d;
            margin-top: 10px;
            font-style: italic;
        }
        
        /* COMPONENTS BREAKDOWN */
        .components {
            margin-top: 30px;
        }
        
        .component-title {
            font-size: 1.1em;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 20px;
            text-align: center;
        }
        
        .component-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 15px;
            margin: 8px 0;
            background: #f8f9fa;
            border-radius: 10px;
            transition: all 0.2s ease;
        }
        
        .component-item:hover {
            background: #e9ecef;
            transform: translateX(5px);
        }
        
        .component-name {
            font-size: 0.95em;
            color: #2c3e50;
            font-weight: 600;
        }
        
        .component-score {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .score-bar-container {
            width: 100px;
            height: 8px;
            background: #e0e0e0;
            border-radius: 10px;
            overflow: hidden;
        }
        
        .score-bar {
            height: 100%;
            border-radius: 10px;
            transition: width 0.5s ease;
        }
        
        .component-signal {
            font-size: 0.85em;
            color: #7f8c8d;
            min-width: 150px;
            text-align: right;
        }
        
        /* MARKET INDICATORS */
        .indicators-section {
            margin-bottom: 40px;
        }
        
        .indicators-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }
        
        .indicator-card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .indicator-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #667eea, #764ba2);
        }
        
        .indicator-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        }
        
        .indicator-name {
            font-size: 0.85em;
            color: #95a5a6;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
        }
        
        .indicator-value {
            font-size: 2.2em;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 8px;
        }
        
        .indicator-change {
            font-size: 1.1em;
            font-weight: 600;
            display: inline-block;
            padding: 4px 12px;
            border-radius: 15px;
        }
        
        .positive {
            color: #00b894;
            background: rgba(0, 184, 148, 0.1);
        }
        
        .negative {
            color: #e17055;
            background: rgba(225, 112, 85, 0.1);
        }
        
        .loading {
            text-align: center;
            color: white;
            font-size: 1.5em;
            padding: 60px;
        }
        
        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 5px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        footer {
            text-align: center;
            color: white;
            margin-top: 60px;
            padding: 30px;
            opacity: 0.9;
            background: rgba(255,255,255,0.1);
            border-radius: 20px;
            backdrop-filter: blur(10px);
        }
        
        @media (max-width: 768px) {
            header h1 {
                font-size: 2em;
            }
            
            .macro-grid {
                grid-template-columns: 1fr;
            }
            
            .indicators-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>📊 Advanced Trading Dashboard</h1>
            <div class="last-update" id="lastUpdate">Caricamento...</div>
        </header>
        
        <div id="loading" class="loading">
            <div class="loading-spinner"></div>
            ⏳ Caricamento analisi avanzata...
        </div>
        
        <div id="dashboard" style="display: none;">
            <!-- MACRO ANALYSIS SECTION -->
            <div class="macro-section">
                <div class="section-title">🎯 Analisi Macro Avanzata (Score 0-100)</div>
                <div class="macro-grid" id="macroGrid">
                    <!-- Cards will be inserted here by JavaScript -->
                </div>
            </div>
            
            <!-- MARKET INDICATORS -->
            <div class="indicators-section">
                <div class="section-title">📈 Indicatori di Mercato</div>
                <div class="indicators-grid">
                    <div class="indicator-card">
                        <div class="indicator-name">VIX (Volatility)</div>
                        <div class="indicator-value" id="vix-value">-</div>
                        <div class="indicator-change" id="vix-change">-</div>
                    </div>
                    
                    <div class="indicator-card">
                        <div class="indicator-name">S&P 500</div>
                        <div class="indicator-value" id="spy-value">-</div>
                        <div class="indicator-change" id="spy-change">-</div>
                    </div>
                    
                    <div class="indicator-card">
                        <div class="indicator-name">Gold</div>
                        <div class="indicator-value" id="gold-value">-</div>
                    </div>
                    
                    <div class="indicator-card">
                        <div class="indicator-name">USD Index (DXY)</div>
                        <div class="indicator-value" id="dxy-value">-</div>
                    </div>
                    
                    <div class="indicator-card">
                        <div class="indicator-name">Bitcoin</div>
                        <div class="indicator-value" id="btc-value">-</div>
                    </div>
                </div>
            </div>
        </div>
        
        <footer>
            <p><strong>⚡ Sistema di Scoring Avanzato</strong></p>
            <p>Integra: Tassi, Inflazione, PIL, COT Report, VIX, DXY, Oro, Equity Momentum, Geopolitica</p>
            <p style="margin-top: 15px; opacity: 0.8;">Aggiornamento automatico ogni ora | Built by Federico</p>
        </footer>
    </div>
    
    <script>
        function createMacroCard(pairData, pairName, currentPrice) {
            const score = pairData.score;
            const percentage = (score / 100) * 100;
            
            // Determina colore score
            let scoreColor;
            if (score >= 75) scoreColor = '#00b894';
            else if (score >= 60) scoreColor = '#00b894';
            else if (score >= 45) scoreColor = '#fdcb6e';
            else if (score >= 30) scoreColor = '#e17055';
            else scoreColor = '#e74c3c';
            
            const components = pairData.components;
            
            let componentsHTML = '';
            for (const [key, comp] of Object.entries(components)) {
                const barPercentage = (comp.score / comp.max) * 100;
                let barColor;
                if (barPercentage >= 70) barColor = '#00b894';
                else if (barPercentage >= 40) barColor = '#fdcb6e';
                else barColor = '#e17055';
                
                const displayName = key.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
                
                componentsHTML += `
                    <div class="component-item">
                        <div class="component-name">${displayName}</div>
                        <div class="component-score">
                            <div class="score-bar-container">
                                <div class="score-bar" style="width: ${barPercentage}%; background: ${barColor};"></div>
                            </div>
                            <span style="font-weight: 700; color: ${scoreColor}; min-width: 40px;">${comp.score}/${comp.max}</span>
                            <span class="component-signal">${comp.signal}</span>
                        </div>
                    </div>
                `;
            }
            
            return `
                <div class="macro-card">
                    <div class="pair-header">
                        <div class="pair-name">${pairName}</div>
                        <div class="pair-price">${currentPrice}</div>
                    </div>
                    
                    <div class="score-container">
                        <div class="score-label">Score Complessivo</div>
                        <div class="score-gauge">
                            <div class="gauge-bg">
                                <div class="gauge-inner">
                                    <div class="score-value" style="color: ${scoreColor};">${score}</div>
                                    <div class="score-max">/100</div>
                                </div>
                            </div>
                        </div>
                        <div class="signal-badge" style="background: ${pairData.signal_color}; color: white;">
                            ${pairData.final_signal}
                        </div>
                        <div class="recommendation">${pairData.recommendation}</div>
                    </div>
                    
                    <div class="components">
                        <div class="component-title">📊 Breakdown Componenti</div>
                        ${componentsHTML}
                    </div>
                </div>
            `;
        }
        
        async function loadData() {
            try {
                const response = await fetch('data/market_data.json');
                const data = await response.json();
                
                document.getElementById('loading').style.display = 'none';
                document.getElementById('dashboard').style.display = 'block';
                
                // Update timestamp
                document.getElementById('lastUpdate').textContent = 
                    `🕐 ${data.last_update}`;
                
                // Create macro cards
                const macroGrid = document.getElementById('macroGrid');
                const eurusdCard = createMacroCard(
                    data.macro_analysis.EURUSD,
                    'EUR/USD',
                    data.indicators.eurusd.value
                );
                const gbpusdCard = createMacroCard(
                    data.macro_analysis.GBPUSD,
                    'GBP/USD',
                    '1.2750' // Placeholder, aggiungeremo dopo
                );
                macroGrid.innerHTML = eurusdCard + gbpusdCard;
                
                // Update market indicators
                document.getElementById('vix-value').textContent = data.indicators.vix.value;
                const vixChange = document.getElementById('vix-change');
                vixChange.textContent = `${data.indicators.vix.change > 0 ? '+' : ''}${data.indicators.vix.change}%`;
                vixChange.className = data.indicators.vix.change > 0 ? 'indicator-change positive' : 'indicator-change negative';
                
                document.getElementById('spy-value').textContent = `$${data.indicators.spy.value}`;
                const spyChange = document.getElementById('spy-change');
                spyChange.textContent = `${data.indicators.spy.change > 0 ? '+' : ''}${data.indicators.spy.change}%`;
                spyChange.className = data.indicators.spy.change > 0 ? 'indicator-change positive' : 'indicator-change negative';
                
                document.getElementById('gold-value').textContent = `$${data.indicators.gold.value}`;
                document.getElementById('dxy-value').textContent = data.indicators.dxy.value;
                document.getElementById('btc-value').textContent = `$${Math.round(data.indicators.bitcoin.value).toLocaleString()}`;
                
            } catch (error) {
                console.error('Errore:', error);
                document.getElementById('loading').innerHTML = 
                    '<div style="color: #e74c3c;">❌ Errore caricamento dati</div>';
            }
        }
        
        loadData();
        setInterval(loadData, 300000); // Refresh ogni 5 minuti
    </script>
</body>
</html>
